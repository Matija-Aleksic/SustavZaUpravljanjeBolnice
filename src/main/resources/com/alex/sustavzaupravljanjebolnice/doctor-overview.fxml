<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import java.lang.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" stylesheets="@hospital-styles.css" xmlns="http://javafx.com/javafx/26"
            fx:controller="com.alex.sustavzaupravljanjebolnice.controller.DoctorViewController">

    <left>
        <VBox maxWidth="320" minWidth="280" prefWidth="300" spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10" right="5" bottom="10" left="10"/>
            </padding>
            <TableView fx:id="doctorsTable" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="doctorColumn" prefWidth="285" text="Doctors"/>
                </columns>
            </TableView>

            <HBox fx:id="doctorCrudContainer" alignment="CENTER" spacing="10">
                <Button fx:id="addDoctorBtn" onAction="#handleAddDoctor" prefWidth="85" text="Add">
                    <styleClass>
                        <String fx:value="btn-primary"/>
                    </styleClass>
                </Button>
                <Button fx:id="editDoctorBtn" onAction="#handleEditDoctor" prefWidth="85" text="Edit">
                    <styleClass>
                        <String fx:value="btn-warning"/>
                    </styleClass>
                </Button>
                <Button fx:id="deleteDoctorBtn" onAction="#handleDeleteDoctor" prefWidth="85" text="Delete">
                    <styleClass>
                        <String fx:value="btn-danger"/>
                    </styleClass>
                </Button>
            </HBox>
        </VBox>
    </left>

    <top>
        <fx:include source="menu.fxml"/>
    </top>

    <center>
        <VBox maxWidth="Infinity" spacing="15" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <GridPane maxWidth="Infinity" hgap="15" vgap="8"
                      style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 6; -fx-border-color: #dee2e6; -fx-border-radius: 6;">
                <columnConstraints>
                    <ColumnConstraints hgrow="NEVER" minWidth="130"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="220"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="NEVER"/>
                    <RowConstraints vgrow="NEVER"/>
                    <RowConstraints vgrow="NEVER"/>
                </rowConstraints>

                <ImageView fx:id="picture" fitHeight="100" fitWidth="100" preserveRatio="true" GridPane.columnIndex="0"
                           GridPane.rowIndex="0" GridPane.rowSpan="3"/>

                <Label fx:id="nameSurname" text="Name Surname" style="-fx-font-size: 16px; -fx-font-weight: bold;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label fx:id="oib" text="OIB" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label fx:id="role" text="Role" style="-fx-text-fill: #6c757d;" GridPane.columnIndex="1"
                       GridPane.rowIndex="2"/>

                <Label fx:id="email" text="Email" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <Label fx:id="phoneNumber" text="Phone Number" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <Label fx:id="address" text="Address" GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                <Label fx:id="salary" text="Salary" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            </GridPane>

            <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" style="-fx-tab-header-background: transparent;">
                <Tab text="Patients &amp; Prescriptions">
                    <HBox spacing="20">
                        <padding>
                            <Insets top="15" right="5" bottom="5" left="5"/>
                        </padding>

                        <VBox HBox.hgrow="ALWAYS" spacing="10" maxWidth="Infinity">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Assigned Patients"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="5">
                                    <Button onAction="#handleAddPatient" text="Add">
                                        <styleClass>
                                            <String fx:value="btn-success"/>
                                        </styleClass>
                                    </Button>
                                    <Button onAction="#handleEditPatient" text="Edit">
                                        <styleClass>
                                            <String fx:value="btn-warning"/>
                                        </styleClass>
                                    </Button>
                                    <Button onAction="#handleDeletePatient" text="Discharge">
                                        <styleClass>
                                            <String fx:value="btn-danger"/>
                                        </styleClass>
                                    </Button>
                                </HBox>
                            </HBox>
                            <TableView fx:id="patientsTable" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="patientNameColumn" prefWidth="240.0" text="Patient Name"/>
                                    <TableColumn fx:id="patientOibColumn" prefWidth="220.0" text="OIB"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <VBox HBox.hgrow="ALWAYS" spacing="10" maxWidth="Infinity">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Active Prescriptions Log"
                                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <HBox spacing="5">
                                    <Button onAction="#handleAddPrescription" text="Prescribe">
                                        <styleClass>
                                            <String fx:value="btn-success"/>
                                        </styleClass>
                                    </Button>
                                    <Button onAction="#handleEditPrescription" text="Modify">
                                        <styleClass>
                                            <String fx:value="btn-warning"/>
                                        </styleClass>
                                    </Button>
                                    <Button onAction="#handleDeletePrescription" text="Revoke">
                                        <styleClass>
                                            <String fx:value="btn-danger"/>
                                        </styleClass>
                                    </Button>
                                </HBox>
                            </HBox>
                            <TableView fx:id="prescriptionsTable" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="prescriptionNameColumn" prefWidth="200.0"
                                                 text="Medication"/>
                                    <TableColumn fx:id="prescriptionPatientColumn" prefWidth="160.0"
                                                 text="Patient Target"/>
                                    <TableColumn fx:id="prescriptionDurationColumn" prefWidth="200.0"
                                                 text="Duration Cycle"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </HBox>
                </Tab>

                <Tab text="Appointments Calendar">
                    <VBox spacing="10">
                        <padding>
                            <Insets top="15" right="5" bottom="5" left="5"/>
                        </padding>
                        <Label text="Scheduled Appointments Timeline"
                               style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                        <TableView fx:id="appointmentsTable" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="appointmentPatientColumn" prefWidth="350.0"
                                             text="Patient Name"/>
                                <TableColumn fx:id="appointmentDateColumn" prefWidth="650.0"
                                             text="Appointment Date &amp; Scheduled Time Timestamp"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>
            </TabPane>
        </VBox>
    </center>

</BorderPane>