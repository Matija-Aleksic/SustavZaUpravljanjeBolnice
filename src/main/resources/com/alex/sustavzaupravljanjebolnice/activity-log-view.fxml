<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.BorderPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="com.alex.sustavzaupravljanjebolnice.controller.ActivityLogController">

    <top>
        <fx:include source="menu.fxml"/>
    </top>

    <center>
        <TableView fx:id="activityTable">

            <columns>

                <TableColumn fx:id="dateColumn"
                             text="Date &amp; Time"
                             prefWidth="220"/>

                <TableColumn fx:id="descriptionColumn"
                             text="Description"
                             prefWidth="450"/>

                <TableColumn fx:id="madeByColumn"
                             text="Made By"
                             prefWidth="180"/>

            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>

        </TableView>
    </center>

</BorderPane>