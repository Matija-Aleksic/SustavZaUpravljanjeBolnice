<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import java.lang.*?>
<ToolBar xmlns:fx="http://javafx.com/fxml/1"
         xmlns="http://javafx.com/javafx/21"
         fx:controller="com.alex.sustavzaupravljanjebolnice.controller.MenuController"
         prefHeight="60.0"
         style="-fx-background-color: #005fac; -fx-padding: 10;">

    <stylesheets>
        <String fx:value="@hospital-styles.css"/>
    </stylesheets>

    <Button text="Hospital" onAction="#handleHospital"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Button text="Doctors" onAction="#handleDoctors"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Button text="Nurses" onAction="#handleNurses"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Button text="Patients" onAction="#handlePatients"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Button text="Appointments" onAction="#handleAppointments"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Button text="Prescriptions" onAction="#handlePrescriptions"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Button text="Logs" onAction="#handleLogs"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

    <Pane HBox.hgrow="ALWAYS"/>

    <Button text="🚪 Logout" onAction="#handleLogout"
            style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8px 16px; -fx-background-color: #d64541;">
        <styleClass>
            <String fx:value="menu-button"/>
        </styleClass>
    </Button>

</ToolBar>

