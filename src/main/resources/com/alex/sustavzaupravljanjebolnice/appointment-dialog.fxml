<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<VBox xmlns:fx="http://javafx.com/fxml/1" spacing="15.0"
      prefWidth="400.0" xmlns="http://javafx.com/javafx/21" stylesheets="@hospital-styles.css"
      fx:controller="com.alex.sustavzaupravljanjebolnice.controller.popup.AppointmentDialogController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Appointment Details">
        <styleClass>
            <String fx:value="label"/>
            <String fx:value="title"/>
        </styleClass>
    </Label>

    <GridPane vgap="10.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="80.0"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="Doctor:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="doctorCombo" prefWidth="250.0" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Patient:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <ComboBox fx:id="patientCombo" prefWidth="250.0" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Date:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="datePicker" prefWidth="250.0" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Time:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="timeField" prefWidth="250.0" promptText="HH:mm (e.g. 14:30)" GridPane.rowIndex="3"
                   GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button mnemonicParsing="false" text="Cancel" onAction="#handleCancel">
            <styleClass>
                <String fx:value="btn-ghost"/>
            </styleClass>
        </Button>
        <Button mnemonicParsing="false" text="Save Appointment" onAction="#handleSave">
            <styleClass>
                <String fx:value="btn-primary"/>
            </styleClass>
        </Button>
    </HBox>

</VBox>