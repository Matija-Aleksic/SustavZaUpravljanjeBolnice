<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="600.0" prefWidth="400.0" stylesheets="@hospital-styles.css"
            xmlns="http://javafx.com/javafx/26"
            fx:controller="com.alex.sustavzaupravljanjebolnice.controller.LoginController">

    <GridPane hgap="10" vgap="10" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
              AnchorPane.topAnchor="0">

        <columnConstraints>
            <ColumnConstraints percentWidth="20"/>
            <ColumnConstraints percentWidth="60"/>
            <ColumnConstraints percentWidth="20"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="10"/>
        </rowConstraints>

        <Label text="Login" GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="1"
               GridPane.valignment="CENTER">
            <font>
                <Font size="24"/>
            </font>
        </Label>

        <TextField fx:id="usernameTextField" prefHeight="40" promptText="Username" GridPane.columnIndex="1"
                   GridPane.halignment="CENTER" GridPane.rowIndex="2"/>

        <PasswordField fx:id="passwordTextField" onAction="#login" prefHeight="40" promptText="Password"
                       GridPane.columnIndex="1" GridPane.halignment="CENTER" GridPane.rowIndex="3"/>

        <Button fx:id="loginButton" onAction="#login" prefHeight="40" text="Login" GridPane.columnIndex="1"
                GridPane.halignment="CENTER" GridPane.rowIndex="4"/>

        <Label fx:id="loginMessageLabel" wrapText="true" GridPane.columnIndex="1" GridPane.halignment="CENTER"
               GridPane.rowIndex="4" GridPane.valignment="CENTER"/>

    </GridPane>
</AnchorPane>
