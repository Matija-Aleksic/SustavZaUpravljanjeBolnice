<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="600.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/24.0.1"
            fx:controller="com.faks.employeetimetrackingsystem.controller.LoginController">

    <GridPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
              hgap="10" vgap="10">

        <columnConstraints>
            <ColumnConstraints percentWidth="20"/>
            <ColumnConstraints percentWidth="60"/>
            <ColumnConstraints percentWidth="20"/>
        </columnConstraints>

        <rowConstraints>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="15"/>
            <RowConstraints percentHeight="10"/>
        </rowConstraints>

        <Label text="Login" GridPane.columnIndex="1" GridPane.rowIndex="0"
               GridPane.halignment="CENTER" GridPane.valignment="CENTER">
            <font>
                <Font size="24"/>
            </font>
        </Label>

        <TextField fx:id="usernameTextField" promptText="Username"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"
                   GridPane.halignment="CENTER" prefHeight="40"/>

        <PasswordField fx:id="passwordTextField" promptText="Password" onAction="#login"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"
                       GridPane.halignment="CENTER" prefHeight="40"/>

        <Button fx:id="loginButton" text="Login" onAction="#login"
                GridPane.columnIndex="1" GridPane.rowIndex="3"
                GridPane.halignment="CENTER" prefHeight="40"/>

        <Label fx:id="loginMessageLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"
               GridPane.halignment="CENTER" GridPane.valignment="CENTER"
               wrapText="true"/>

    </GridPane>
</AnchorPane>