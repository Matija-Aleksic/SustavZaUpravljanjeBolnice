<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<BorderPane xmlns:fx="http://javafx.com/fxml/1" prefHeight="700.0"
            prefWidth="1000.0" xmlns="http://javafx.com/javafx/21"
            stylesheets="@hospital-styles.css"
            fx:controller="com.alex.sustavzaupravljanjebolnice.controller.ReceptionistViewController">

    <top>
        <MenuBar BorderPane.alignment="CENTER">
            <Menu mnemonicParsing="false" text="File">
                <MenuItem mnemonicParsing="false" text="Close"/>
            </Menu>
        </MenuBar>
    </top>

    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <styleClass>
                    <String fx:value="toolbar"/>
                </styleClass>
                <Button mnemonicParsing="false" text="New Appointment" onAction="#handleAddAppointment">
                    <styleClass>
                        <String fx:value="btn-primary"/>
                    </styleClass>
                </Button>
                <Button mnemonicParsing="false" text="Edit Selected" onAction="#handleEditAppointment">
                    <styleClass>
                        <String fx:value="btn-primary"/>
                    </styleClass>
                </Button>
                <Button mnemonicParsing="false" text="Delete Selected" onAction="#handleDeleteAppointment">
                    <styleClass>
                        <String fx:value="btn-danger"/>
                    </styleClass>
                </Button>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Sort by:"/>
                <ComboBox fx:id="sortComboBox" prefWidth="150.0"/>
            </HBox>

            <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="75.0" text="ID"/>
                    <TableColumn fx:id="colDate" prefWidth="200.0" text="Date &amp; Time"/>
                    <TableColumn fx:id="colDoctor" prefWidth="250.0" text="Doctor"/>
                    <TableColumn fx:id="colPatient" prefWidth="250.0" text="Patient"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

</BorderPane>